{
  "name": "@tc96/filter-builder",
  "version": "0.1.0",
  "description": "Domain-neutral filter builder for React applications using COSS and Base UI.",
  "type": "module",
  "license": "MIT",
  "author": "Gabriel Melo",
  "keywords": [
    "base-ui",
    "coss",
    "filter",
    "filter-builder",
    "react",
    "saas"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gblsmlo/filter-builder.git"
  },
  "homepage": "https://github.com/gblsmlo/filter-builder#readme",
  "bugs": {
    "url": "https://github.com/gblsmlo/filter-builder/issues"
  },
  "packageManager": "bun@1.3.14",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "registry",
    "registry.json",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./registry": "./registry/filter-builder.json",
    "./registry/filter-builder.json": "./registry/filter-builder.json"
  },
  "scripts": {
    "build": "bun run clean && bun build ./src/index.ts ./src/core.ts --outdir ./dist --target browser --format esm --packages external && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist storybook-static",
    "lint": "biome check --write .",
    "lint:ci": "biome ci .",
    "prepare": "bun run build",
    "prepublishOnly": "bun run build",
    "pack:check": "npm pack --dry-run",
    "storybook": "storybook dev -p 6007 --no-open",
    "storybook:build": "storybook build",
    "test": "bun test",
    "toolchain:check": "sh scripts/check-toolchain.sh",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.21.0",
    "tailwind-merge": "3.6.0"
  },
  "peerDependencies": {
    "@base-ui/react": ">=1.6.0 <2",
    "react": ">=19.1.1 <20",
    "react-dom": ">=19.1.1 <20",
    "tailwindcss": ">=4.2.2 <5"
  },
  "devDependencies": {
    "@base-ui/react": "1.6.0",
    "@biomejs/biome": "2.3.4",
    "@storybook/addon-a11y": "10.5.0",
    "@storybook/addon-docs": "10.5.0",
    "@tc96/biome-config": "2.3.0",
    "@storybook/react-vite": "10.5.0",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/react": "^16.3.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "jsdom": "^26.1.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "storybook": "10.5.0",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.3"
  }
}
